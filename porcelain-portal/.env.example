# Generate a 32-byte hex key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here

# Stripe keys (use test mode keys for development)
# No webhook needed — server polls Stripe directly
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_ID=price_xxx

# JWT secret for decryption tokens
JWT_SECRET=your_jwt_secret_here

# Server port
PORT=3000
